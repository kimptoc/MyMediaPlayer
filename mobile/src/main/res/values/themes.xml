<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyMediaPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- LCARS Light Theme -->
        <item name="colorPrimary">@color/lcars_light_orange</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/lcars_orange</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/lcars_cyan</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/lcars_surface_variant</item>
        <item name="colorOnSecondaryContainer">@color/lcars_warm_white</item>
        <item name="colorTertiary">@color/lcars_purple</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/lcars_surface</item>
        <item name="colorOnTertiaryContainer">@color/lcars_warm_white</item>
        <item name="colorError">@color/lcars_hot_pink</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/lcars_hot_pink</item>
        <item name="colorOnErrorContainer">@color/white</item>
        <item name="android:colorBackground">@color/lcars_light_bg</item>
        <item name="colorOnBackground">@color/black</item>
        <item name="colorSurface">@color/lcars_light_bg</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">@color/lcars_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/lcars_dim_white</item>
        <item name="colorOutline">@color/lcars_dim_white</item>
    </style>

    <style name="Theme.MyMediaPlayer" parent="Base.Theme.MyMediaPlayer" />
</resources>
